{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HAVEN Perspective Document",
  "type": "object",
  "required": ["pre", "during", "post"],
  "properties": {
    "pre": {"$ref": "#/$defs/snapshot"},
    "during": {"$ref": "#/$defs/snapshot"},
    "post": {"$ref": "#/$defs/snapshot"}
  },
  "$defs": {
    "snapshot": {
      "type": "object",
      "required": ["purposes", "interests", "constraints"],
      "properties": {
        "purposes": {
          "type": "array",
          "items": {"type": "string"}
        },
        "goals": {
          "type": "array",
          "items": {"$ref": "#/$defs/goal"}
        },
        "interests": {
          "type": "array",
          "items": {"type": "string"}
        },
        "constraints": {
          "type": "array",
          "items": {"type": "string"}
        },
        "visibility_policy_ref": {"type": "string"}
      }
    },
    "goal": {
      "type": "object",
      "required": ["goal_id", "description"],
      "properties": {
        "goal_id": {"type": "string"},
        "purpose_id": {"type": "string"},
        "description": {"type": "string"},
        "metric": {"type": "string"},
        "baseline": {"type": "string"},
        "target": {"type": "string"},
        "timeframe": {"type": "string"},
        "data_source": {"type": "string"},
        "evidence_rule": {"type": "string"},
        "indicator_refs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "incentive_only": {"type": "boolean"}
      }
    }
  }
}
