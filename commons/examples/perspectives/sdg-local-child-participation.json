        "timeframe": "2026-season",
        "data_source": "#/perspective/pre/goals",
        "evidence_rule": "midseason_gap_delta <= 0.00",
        "indicator_refs": [
          "4.5.1",
          "10.2.1"
        ],
        "incentive_only": true
      }
    ],
    "interests": [
      "interest.children",
      "interest.community"
    ],
    "constraints": [
      "review_dropout_reasons_monthly"
    ],
    "visibility_policy_ref": "policy://team"
  },
